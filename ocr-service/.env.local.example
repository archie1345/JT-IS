# Copy this file to .env.local and edit it for your own machine.
# .env.local is ignored by git.

# Optional: exact Python executable.
# Leave blank to let the startup script create/use ocr-service\.venv-paddle
# with Python 3.12/3.11/3.10 when available.
# OCR_PYTHON=f:\conda\envs\gpu-jupyter\python.exe

# Optional: environment root for Conda/GPU setups.
# OCR_ENV_ROOT=f:\conda\envs\gpu-jupyter

# Prefer gpu:0 when the selected Python has a CUDA Paddle runtime, otherwise use CPU.
OCR_PADDLE_DEVICE=auto
OCR_PADDLE_ENABLE_MKLDNN=0

# Leave enabled for a normal CPU test setup. Set to 0 only when OCR_PYTHON points
# to an environment that already has paddlepaddle-gpu or another Paddle runtime.
OCR_INSTALL_PADDLE=1

# Optional: Tesseract path. Leave blank if installed in the default location or on PATH.
# OCR_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

OCR_STUB_MODELSCOPE=1
OCR_FAST_MODE=1
OCR_MAX_PAGES=0
OCR_PREFER_PDF_TEXT=1
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
FLAGS_use_mkldnn=0
